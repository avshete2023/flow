<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>{"timestamp":"%d{yyyy-MM-dd'T'HH:mm:ss.SSSXXX}","level":"%level","module":"%replace(%logger){'^com\\.flow\\.([^\\.]+)\\..*','$1'}","logger":"%logger{36}","correlationId":"%X{correlationId:-n/a}","message":"%replace(%replace(%msg){'(?i)(password|secret)=[^,\\s]*','$1=****'}){'(?i)(token|authorization|jwt)=[^,\\s]*','$1=****'}"}%n</pattern>
        </encoder>
    </appender>

    <root level="INFO">
        <appender-ref ref="STDOUT"/>
    </root>
</configuration>

